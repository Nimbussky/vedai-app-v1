# ============================================
# VEDAI — Environment Variables (copy this to .env.local)
# Get free API keys from each service to unlock that AI provider
# ============================================

# 1. GLM / Zhipu AI — PRIMARY backbone (free tier)
# Sign up: https://open.bigmodel.cn/
GLM_API_KEY=your_glm_api_key_here

# 2. Groq — Ultra-fast Llama inference (free)
# Sign up: https://console.groq.com/keys
GROQ_API_KEY=

# 3. Cerebras — Fast free tier
# Sign up: https://inference.cerebras.ai/
CEREBRAS_API_KEY=

# 4. DeepSeek — High-quality reasoning
# Sign up: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# 5. Gemini — Google AI (free)
# Sign up: https://aistudio.google.com/
GEMINI_API_KEY=

# 6. Mistral — Good quality (free)
# Sign up: https://console.mistral.ai/
MISTRAL_API_KEY=

# 7. OpenRouter — 100+ model gateway (free tiers)
# Sign up: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# 8. Ollama — Local AI (no key needed)
# Install: https://ollama.com/ && ollama pull llama3.3
OLLAMA_BASE_URL=http://localhost:11434

# Cloudflare (for D1 database + deployment)
CLOUDFLARE_API_KEY=
CLOUDFLARE_API_TOKEN=

# VedAstro API (free, open source)
VEDASTRO_API_URL=https://api.vedastro.org

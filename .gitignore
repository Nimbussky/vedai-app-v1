# ============================================
# VEDAI — .gitignore
# ============================================

# Dependencies
node_modules/

# Build outputs
.next/
out/
dist/
build/

# Environment (contains real API keys — NEVER commit)
.env.local
.env*.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Next.js
.next/
tsconfig.tsbuildinfo
next-env.d.ts

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Drizzle
drizzle/

# Local database
*.db
*.db-journal
